<?xml version="1.0"?>
<robot name="simple_2d_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- robot_namespace: ROS node namespace for Gazebo plugins. frame_prefix: TF link prefix, e.g. "robot2/" or "" for global. -->
  <xacro:arg name="robot_namespace" default="/"/>
  <xacro:arg name="frame_prefix" default=""/>

  <xacro:property name="lnk_bf" value="$(arg frame_prefix)base_footprint"/>
  <xacro:property name="lnk_base" value="$(arg frame_prefix)base_link"/>
  <xacro:property name="lnk_lw" value="$(arg frame_prefix)left_wheel_link"/>
  <xacro:property name="lnk_rw" value="$(arg frame_prefix)right_wheel_link"/>
  <xacro:property name="lnk_laser" value="$(arg frame_prefix)laser_link"/>
  <xacro:property name="lnk_imu" value="$(arg frame_prefix)imu_link"/>
  <xacro:property name="lnk_cam" value="$(arg frame_prefix)camera_link"/>
  <xacro:property name="lnk_odom" value="$(arg frame_prefix)odom"/>

  <xacro:property name="base_length" value="0.40"/>
  <xacro:property name="base_width" value="0.30"/>
  <xacro:property name="base_height" value="0.12"/>
  <xacro:property name="wheel_radius" value="0.06"/>
  <xacro:property name="wheel_width" value="0.03"/>
  <xacro:property name="wheel_sep" value="0.26"/>

  <link name="${lnk_bf}"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="${lnk_bf}"/>
    <child link="${lnk_base}"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="${lnk_base}">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="12.0"/>
      <inertia ixx="0.12" ixy="0.0" ixz="0.0" iyy="0.12" iyz="0.0" izz="0.20"/>
    </inertial>
    <visual>
      <origin xyz="0 0 ${base_height/2}"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="gray">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_height/2}"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
  </link>

  <link name="${lnk_lw}">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
  </link>

  <link name="${lnk_rw}">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="${lnk_base}"/>
    <child link="${lnk_lw}"/>
    <origin xyz="0 ${wheel_sep/2} ${wheel_radius}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="${lnk_base}"/>
    <child link="${lnk_rw}"/>
    <origin xyz="0 ${-wheel_sep/2} ${wheel_radius}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="${lnk_laser}">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.0003" ixy="0.0" ixz="0.0" iyy="0.0003" iyz="0.0" izz="0.0003"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.04"/>
      </geometry>
      <material name="blue">
        <color rgba="0.1 0.2 0.8 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="laser_joint" type="fixed">
    <parent link="${lnk_base}"/>
    <child link="${lnk_laser}"/>
    <origin xyz="0.12 0 ${base_height + 0.03}" rpy="0 0 0"/>
  </joint>

  <link name="${lnk_imu}">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="imu_joint" type="fixed">
    <parent link="${lnk_base}"/>
    <child link="${lnk_imu}"/>
    <origin xyz="0 0 ${base_height + 0.02}" rpy="0 0 0"/>
  </joint>

  <link name="${lnk_cam}">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0002" iyz="0.0" izz="0.0002"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.04 0.04 0.03"/>
      </geometry>
      <material name="green">
        <color rgba="0.1 0.7 0.2 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="${lnk_base}"/>
    <child link="${lnk_cam}"/>
    <origin xyz="0.18 0 ${base_height + 0.05}" rpy="0 0 0"/>
  </joint>

  <gazebo reference="${lnk_lw}">
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
  </gazebo>
  <gazebo reference="${lnk_rw}">
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
  </gazebo>

  <gazebo reference="${lnk_laser}">
    <sensor type="ray" name="scan">
      <always_on>true</always_on>
      <visualize>false</visualize>
      <update_rate>15.0</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.10</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin name="laser_controller" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <namespace>$(arg robot_namespace)</namespace>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>${lnk_laser}</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="${lnk_imu}">
    <sensor type="imu" name="imu_sensor">
      <always_on>true</always_on>
      <update_rate>100.0</update_rate>
      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <namespace>$(arg robot_namespace)</namespace>
          <remapping>~/out:=imu/data</remapping>
        </ros>
        <frame_name>${lnk_imu}</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="${lnk_cam}">
    <sensor type="camera" name="front_camera">
      <always_on>true</always_on>
      <update_rate>15</update_rate>
      <camera name="camera">
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>30</far>
        </clip>
      </camera>
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>$(arg robot_namespace)</namespace>
          <remapping>~/image_raw:=camera/image_raw</remapping>
          <remapping>~/camera_info:=camera/camera_info</remapping>
        </ros>
        <frame_name>${lnk_cam}</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo>
    <plugin name="diff_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>$(arg robot_namespace)</namespace>
      </ros>
      <update_rate>50</update_rate>
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>${wheel_sep}</wheel_separation>
      <wheel_diameter>${2 * wheel_radius}</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>${lnk_odom}</odometry_frame>
      <robot_base_frame>${lnk_bf}</robot_base_frame>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
    </plugin>
  </gazebo>
</robot>
